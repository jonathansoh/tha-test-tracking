# Supabase — from your project's Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service role key (SECRET — server only). Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Domain used to build synthetic emails for username-only auth.
# Any value works; it is never emailed. Keep it stable once users exist.
INTERNAL_EMAIL_DOMAIN=users.tracker.local

# Base URL used when generating invite links (no trailing slash).
# Local dev: http://localhost:3000 — in Vercel set to your production URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
